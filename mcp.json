{
  "mcpServers": {
    "Core-Utilities": {
      "time": {
        "command": "python",
        "args": [
          "-m",
          "mcp_server_time"
        ],
        "env": {
          "TZ": "Europe/Stockholm"
        },
        "autoStart": true,
        "description": "Provides tools to get the current time and date."
      }
    },
    "AI-and-Reasoning": {
      "pollinations": {
        "command": "npx",
        "args": [
          "-y",
          "@pollinations/model-context-protocol"
        ],
        "type": "stdio",
        "restartOnFailure": true,
        "autoStart": true,
        "description": "Provides AI image generation through Pollinations services. 🎨"
      },
      "mcp-sequentialthinking-tools": {
        "command": "npx",
        "args": [
          "-y",
          "mcp-sequentialthinking-tools"
        ],
        "type": "stdio",
        "restartOnFailure": true,
        "autoStart": true,
        "description": "Provides advanced sequential thinking tools with persistent state."
      }
    },
    "Memory-and-Storage": {
      "basic-memory": {
        "type": "stdio",
        "command": "uvx",
        "args": [
          "basic-memory",
          "mcp"
        ],
        "autoStart": true,
        "description": "Basic Memory MCP server via direct command.",
        "env": {
          "BASIC_MEMORY_PROJECT_ROOT": "."
        }
      },
      "deepwiki": {
        "url": "https://mcp.deepwiki.com/sse",
        "description": "DeepWiki MCP over SSE for knowledge lookup."
      },
      "context7": {
        "url": "https://mcp.context7.com/mcp",
        "headers": {
          "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
          "Accept": "application/json, text/event-stream"
        }
      }
    },
    "Development-and-Code": {
      "playwright": {
        "command": "npx",
        "args": [
          "-y",
          "@playwright/mcp"
        ],
        "autoApprove": [
          "open_page",
          "screenshot"
        ],
        "type": "stdio",
        "autoStart": true,
        "description": "Lets the AI control a web browser for scraping and automation. 🌐"
      }
    }
  },
  "inputs": []
}
