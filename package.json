{
    "name": "joodug-rpglitch",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "npm run sync && vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run && npm run test:unit -- --run && npm run test:e2e",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "lint": "node tools/qa/warden.js audit",
        "lint:fix": "node tools/ops/conductor.js hygiene",
        "format": "prettier --write .",
        "lint:js": "eslint src",
        "lint:js:fix": "eslint src --fix",
        "lint:css": "stylelint \"src/**/*.scss\"",
        "lint:css:fix": "stylelint \"src/**/*.scss\" --fix",
        "lint:html": "node tools/qa/htmlhint.js",
        "hygiene": "node tools/ops/conductor.js hygiene",
        "analyze": "node tools/qa/analyze-css.js",
        "validate": "npm-run-all lint:fix test hygiene",
        "deploy": "npm run sync && npm run validate && npm run build",
        "sync": "node tools/ops/conductor.js sync all",
        "sync:libs": "node tools/ops/sync.js --libs",
        "sync:ignores": "node tools/ops/conductor.js sync ignores",
        "sync:colors": "node tools/ops/conductor.js sync colors",
        "sync:mcp": "node tools/ops/conductor.js sync mcp",
        "ingest": "node tools/scholar/cli.js ingest",
        "scholar": "node tools/scholar/cli.js",
        "warden": "node tools/qa/warden.js",
        "conductor": "node tools/ops/conductor.js",
        "qa:diagnostics": "node tools/qa/diagnostics.js",
        "test:unit": "vitest",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@mendable/firecrawl-js": "^4.11.1",
        "@modelcontextprotocol/sdk": "^1.25.3",
        "@pinecone-database/pinecone": "^6.1.3",
        "@supabase/supabase-js": "^2.90.1",
        "dexie": "^3.2.4",
        "dompurify": "^3.0.5",
        "dotenv": "^17.2.3",
        "ignore": "^7.0.5"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.39.1",
        "@playwright/test": "^1.57.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.2",
        "@testing-library/svelte": "^5.2.8",
        "@types/node": "^22",
        "@vitest/browser": "^4.0.17",
        "@vitest/browser-playwright": "^4.0.15",
        "autoprefixer": "^10.4.14",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.13.1",
        "fake-indexeddb": "^6.2.5",
        "globals": "^16.5.0",
        "htmlhint": "^1.8.0",
        "jsdom": "^25.0.1",
        "mdsvex": "^0.12.6",
        "npm-run-all": "^4.1.5",
        "playwright": "^1.57.0",
        "postcss": "^8.4.26",
        "postcss-scss": "^4.0.9",
        "prettier": "3.8.0",
        "prettier-plugin-svelte": "^3.4.0",
        "sass": "^1.97.2",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "svelte": "^5.46.1",
        "svelte-check": "^4.3.5",
        "svelte-eslint-parser": "^1.4.1",
        "svelte-preprocess": "^6.0.3",
        "vite": "^6.0.7",
        "vite-plugin-devtools-json": "^1.0.0",
        "vite-plugin-singlefile": "^2.0.4",
        "vitest": "^4.0.15",
        "vitest-browser-svelte": "^2.0.1"
    }
}
