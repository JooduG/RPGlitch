{
  "name": "joodug-rpglitch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "// --- CORE WORKFLOW --- //": "",
    "dev": "vite",
    "preview": "vite preview --port 8080",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "deploy": "run-s deploy:prepare deploy:auto",
    "deploy:auto": "node .agents/skills/release/scripts/deploy-perchance.js",
    "deploy:prepare": "run-s sync format deploy:check build",
    "deploy:check": "run-s lint:fix audit test",
    "// --- CHECKS & LINTING --- //": "",
    "verify": "run-s lint audit test",
    "check": "run-s verify",
    "clean": "run-p --aggregate-output audit:security lint audit:backlog",
    "format": "prettier --write .",
    "lint": "run-p --aggregate-output lint:js lint:css lint:md",
    "lint:fix": "run-p --aggregate-output lint:js:fix lint:css:fix lint:md:fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix --cache",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"**/*.mdx\" \"!node_modules\" \"!**/archive/**\" \"!tmp\" \"!scribbles.md\"",
    "lint:design": "designmd lint DESIGN.md",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"**/*.mdx\" \"!node_modules\" \"!**/archive/**\" \"!tmp\" \"!scribbles.md\"",
    "// --- AUDITS --- //": "",
    "audit": "run-p --aggregate-output audit:backlog audit:css audit:design audit:design-spec audit:nomenclature audit:perf audit:security audit:simulation audit:svelte audit:templates",
    "audit:design-spec": "npm run tool:audit-design-spec",
    "audit:backlog": "npm run tool:sync-backlog",
    "audit:css": "npm run tool:audit-css",
    "audit:design": "npm run tool:audit-design",
    "audit:nomenclature": "npm run tool:audit-nomenclature",
    "audit:perf": "svelte-check",
    "audit:security": "npm run tool:audit-security",
    "audit:simulation": "vitest run .agents/skills/simulation/scripts/simulation-audit.test.js",
    "audit:svelte": "npm run tool:audit-svelte",
    "audit:templates": "npm run tool:audit-templates",
    "// --- TESTING --- //": "",
    "test": "run-s test:unit test:design",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:design": "vitest run .agents/skills/design/scripts/design-sync.test.js",
    "// --- DATA & KNOWLEDGE --- //": "",
    "knowledge": "run-p --aggregate-output knowledge:archive knowledge:select knowledge:upsert",
    "knowledge:archive": "npm run tool:knowledge -- archive",
    "knowledge:select": "npm run tool:knowledge -- select",
    "knowledge:upsert": "npm run tool:knowledge -- upsert",
    "// --- SWARM --- //": "",
    "swarm": "npm run tool:summarize -- swarm:plan swarm:dispatch swarm:analyze swarm:merge",
    "swarm:plan": "npm run tool:swarm -- .agents/skills/swarm/scripts/automation/swarm-plan.ts",
    "swarm:dispatch": "npm run tool:swarm -- .agents/skills/swarm/scripts/automation/swarm-dispatch.ts",
    "swarm:analyze": "npm run tool:swarm -- .agents/skills/swarm/scripts/automation/swarm-analyze.ts",
    "swarm:merge": "npm run tool:swarm -- .agents/skills/swarm/scripts/automation/swarm-merge.ts",
    "swarm:brief:agent": "node .agents/skills/swarm/scripts/swarm-engine.js brief --agent",
    "swarm:brief:human": "node .agents/skills/swarm/scripts/swarm-engine.js brief --human",
    "// --- SYNC & FORGE --- //": "",
    "sync": "run-p --aggregate-output sync:ignores sync:design",
    "sync:design": "npm run tool:sync-design",
    "sync:ignores": "npm run tool:sync-ignores",
    "forge:skill": "npm run tool:forge-skill",
    "forge:svelte": "npm run tool:forge-svelte",
    "// --- TOOLING ABSTRACTS --- //": "",
    "tool:summarize": "node .agents/skills/executive/scripts/summarize.js",
    "tool:swarm": "tsx --tsconfig jsconfig.json",
    "tool:knowledge": "node .agents/skills/developer-database/scripts/developer-database.js",
    "tool:audit-css": "node .agents/skills/css/scripts/audit-css.js",
    "tool:audit-design": "node .agents/skills/design/scripts/audit-design.js",
    "tool:audit-nomenclature": "node .agents/skills/legislative/scripts/audit-nomenclature.js",
    "tool:audit-security": "node .agents/skills/security/scripts/audit-security.js",
    "tool:audit-svelte": "node .agents/skills/svelte/scripts/audit-svelte.js",
    "tool:audit-templates": "node .agents/skills/legislative/scripts/audit-templates.js",
    "tool:sync-backlog": "node .agents/skills/legislative/scripts/sync-backlog.js",
    "tool:forge-skill": "node .agents/skills/legislative/scripts/forge-skill.js",
    "tool:forge-svelte": "node .agents/skills/svelte/scripts/forge-svelte.js",
    "tool:sync-design": "node .agents/skills/design/scripts/design-sync.js",
    "tool:audit-design-spec": "node .agents/skills/design/scripts/audit-design-spec.js",
    "tool:sync-ignores": "node .agents/skills/executive/scripts/sync.js"
  },
  "dependencies": {
    "@_davideast/stitch-mcp": "^0.9.0",
    "@google/jules": "^0.1.42",
    "@google/jules-sdk": "^0.2.0",
    "@google/stitch-sdk": "^0.3.5",
    "@internationalized/date": "^3.12.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nekzus/mcp-server": "^1.18.0",
    "@notionhq/notion-mcp-server": "*",
    "@pinecone-database/mcp": "*",
    "@pinecone-database/pinecone": "^7.2.0",
    "@playwright/mcp": "^0.0.75",
    "@pollinations/model-context-protocol": "^1.0.15",
    "@supabase/mcp-server-supabase": "*",
    "@supabase/supabase-js": "^2.107.0",
    "@sveltejs/mcp": "*",
    "@waldzellai/clear-thought-onepointfive": "^0.2.1",
    "@waldzellai/collaborative-reasoning": "^0.1.3",
    "@waldzellai/decision-framework": "^0.1.3",
    "@waldzellai/metacognitive-monitoring": "^0.1.3",
    "@waldzellai/scientific-method": "^0.1.3",
    "@waldzellai/stochasticthinking": "^0.0.1",
    "@waldzellai/structured-argumentation": "^0.1.3",
    "@waldzellai/visual-reasoning": "^0.1.1",
    "bits-ui": "^2.18.1",
    "chrome-devtools-mcp": "^0.26.0",
    "dexie": "^4.4.3",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "find-up": "^7.0.0",
    "firecrawl-mcp": "^3.20.2",
    "ignore": "^7.0.5",
    "markdown-it": "^14.2.0",
    "mcp-mermaid": "^0.4.1",
    "mcp-sequentialthinking-tools": "^0.0.5",
    "octokit": "^4.1.4",
    "paneforge": "^1.0.2",
    "runed": "^0.37.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@github/markdownlint-github": "^0.8.0",
    "@google/design.md": "^0.2.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-markdownlint": "^0.10.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.19.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.22.1",
    "markdownlint-cli2-formatter-pretty": "^0.0.10",
    "mdsvex": "^0.12.7",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.3",
    "prettier-plugin-sort-package-json": "^1.1.0",
    "prettier-plugin-svelte": "^4.1.0",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-prettier": "^5.0.3",
    "svelte": "^5.56.1",
    "svelte-check": "^4.5.0",
    "svelte-eslint-parser": "^1.7.1",
    "svelte-preprocess": "^6.0.5",
    "tsx": "^4.22.4",
    "vite": "^8.0.16",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.1",
    "devalue": "^5.8.1",
    "express-rate-limit": "^8.5.0",
    "hono": "^4.12.16",
    "ip-address": "^10.1.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "svelte": "^5.56.1",
    "toad-cache": "3.7.0",
    "uuid": "^14.0.0"
  }
}
