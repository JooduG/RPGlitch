    "// --- CHECKS & LINTING --- //": "",
    "verify": "npm run tool:summarize:sequential lint audit test",
    "check": "run npm verify",
    "clean": "npm run tool:summarize:parallel audit:security lint audit:backlog",
    "lint:prettier:fix": "prettier --write .",
    "lint:prettier": "prettier --check .",
    "lint": "npm run tool:summarize:parallel lint:js lint:css lint:md lint:prettier",
