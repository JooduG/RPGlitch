{
    "name": "joodug-rpglitch",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview --port 8080",
        "check": "svelte-check --tsconfig ./jsconfig.json",
        "format": "prettier --write .",
        "sync": "node .agent/skills/project/scripts/sync.js",
        "lint": "npm-run-all --parallel lint:*",
        "lint:js": "eslint src",
        "lint:css": "node .agent/skills/styling/scripts/style_audit.js",
        "lint:fix": "npm-run-all --parallel lint:*:fix",
        "lint:js:fix": "eslint src --fix",
        "lint:css:fix": "stylelint \"src/**/*.scss\" --fix",
        "audit:svelte": "node .agent/skills/svelte/scripts/audit_legacy.js",
        "scaffold:component": "node .agent/skills/svelte/scripts/scaffold_component.js",
        "test": "npm run test:unit && npm run audit:security",
        "test:unit": "vitest",
        "audit:security": "node .agent/skills/security/scripts/security-scan.js",
        "test:e2e": "playwright test",
        "test:ui": "vitest --ui",
        "verify": "npm run check && npm run lint && npx vitest run",
        "deploy": "npm run verify && npm run build"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "@pinecone-database/pinecone": "^6.1.4",
        "@playwright/mcp": "^0.0.64",
        "@pollinations/model-context-protocol": "^1.0.15",
        "@supabase/supabase-js": "^2.95.3",
        "@waldzellai/clear-thought-onepointfive": "^0.2.1",
        "@waldzellai/stochasticthinking": "^0.0.1",
        "@waldzellai/visual-reasoning": "^0.1.1",
        "dexie": "^3.2.4",
        "dompurify": "^3.0.5",
        "dotenv": "^17.3.1",
        "firecrawl-mcp": "^3.9.0",
        "ignore": "^7.0.5",
        "mcp-sequentialthinking-tools": "^0.0.4",
        "paneforge": "^1.0.2",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.39.1",
        "@playwright/test": "^1.57.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.2",
        "@testing-library/svelte": "^5.2.8",
        "@types/node": "^22",
        "@vitest/browser": "^4.0.17",
        "@vitest/browser-playwright": "^4.0.15",
        "autoprefixer": "^10.4.24",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.13.1",
        "fake-indexeddb": "^6.2.5",
        "globals": "^16.5.0",
        "htmlhint": "^1.8.0",
        "jsdom": "^25.0.1",
        "mdsvex": "^0.12.6",
        "npm-run-all": "^4.1.5",
        "playwright": "^1.57.0",
        "postcss": "^8.5.6",
        "postcss-scss": "^4.0.9",
        "prettier": "3.8.0",
        "prettier-plugin-svelte": "^3.4.0",
        "sass": "^1.97.3",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "svelte": "^5.46.1",
        "svelte-check": "^4.3.5",
        "svelte-eslint-parser": "^1.4.1",
        "svelte-preprocess": "^6.0.3",
        "vite": "^6.0.7",
        "vite-plugin-devtools-json": "^1.0.0",
        "vite-plugin-singlefile": "^2.0.4",
        "vitest": "^4.0.15",
        "vitest-browser-svelte": "^2.0.1"
    }
