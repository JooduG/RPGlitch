    "audit:project": "npm run tool:audit-project",
    "// --- TESTING --- //": "",
    "test": "npm run tool:summarize:sequential test:unit test:design",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:design": "vitest run .agents/skills/design/scripts/sync-css.test.js",
    "// --- DATA & KNOWLEDGE --- //": "",
    "knowledge": "npm run tool:summarize:parallel knowledge:archive knowledge:select knowledge:upsert",
    "knowledge:archive": "npm run tool:knowledge -- archive",
    "knowledge:select": "npm run tool:knowledge -- select",
    "knowledge:upsert": "npm run tool:knowledge -- upsert",
    "// --- SWARM --- //": "",
    "swarm:plan": "node .agents/skills/swarm/scripts/cli.js plan",
    "swarm:dispatch": "node .agents/skills/swarm/scripts/cli.js dispatch",
    "swarm:status": "node .agents/skills/swarm/scripts/cli.js status",
    "swarm:merge": "node .agents/skills/swarm/scripts/cli.js merge",
    "swarm:cancel": "node .agents/skills/swarm/scripts/cli.js cancel",
    "// --- SYNC & FORGE --- //": "",
    "sync": "npm run tool:summarize:parallel sync:ignores sync:css",
    "sync:css": "npm run tool:sync-css",
    "sync:ignores": "npm run tool:sync-ignores",
    "forge:skill": "npm run tool:forge-skill",
    "forge:svelte": "npm run tool:forge-svelte",
    "// --- TOOLING ABSTRACTS --- //": "",
    "tool:summarize:sequential": "node C:/Users/johng/.gemini/config/skills/master-dispatcher/scripts/summarize.js --mode=sequential",
