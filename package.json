{
  "name": "joodug",
  "version": "1.0.6",
  "description": "A unified development and deployment workspace for Glitch projects.",
  "private": true,
  "scripts": {
    "deploy": "npm run sync && npm run lint:fix && npm run build && npm run test",
    "//--- SETUP & SYNC ---": "",
    "setup": "npm install && npm run sync && npm run build",
    "sync": "npm run sync:ignores && npm run sync:rules && npm run sync:mcp && npm run sync:configs && npm run sync:libs",
    "sync:markdownlint-globs": "node build/scripts/generate-markdownlint-globs.js",
    "sync:ignores": "node build/scripts/sync-ignores.js",
    "sync:rules": "node build/scripts/sync-rules.js",
    "sync:mcp": "node build/scripts/sync-mcp.js",
    "sync:configs": "node build/scripts/sync-configs.js",
    "sync:tool-configs": "node build/scripts/sync-tool-configs.js",
    "sync:libs": "node build/scripts/sync-libs.js",
    "sync:hub": "node build/scripts/sync-hub.js",
    "//--- LINTING & TESTING ---": "",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run lint:md",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js": "eslint -c build/config/.eslintrc.js .",
    "lint:js:fix": "eslint -c build/config/.eslintrc.js . --fix",
    "lint:css": "stylelint \"**/*.scss\" --config build/config/.stylelintrc.json",
    "lint:css:fix": "stylelint \"**/*.scss\" --config build/config/.stylelintrc.json --fix",
    "lint:html": "htmlhint '**/*.html' --ignore 'build/output/**/*.html' --ignore '**/coverage/**/*'",
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.jsonc",
    "test": "jest",
    "//--- BUILDING ---": "",
    "build": "npm run build:rpglitch && npm run build:imageglitch",
    "build:combine": "node build/scripts/build-combine.js",
    "build:copy": "node build/scripts/build-and-copy.js",
    "build:hub": "node build/scripts/sync-hub.js",
    "build:imageglitch": "node build/scripts/build-imageglitch.js",
    "build:rpglitch": "node build/scripts/build-rpglitch.js"
  },
  "keywords": [
    "ai",
    "agent",
    "monorepo"
  ],
  "author": "JooduG",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@eslint/js": "^9.35.0",
    "babel-jest": "^30.1.2",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.9",
    "eslint": "^9.6.0",
    "eslint-plugin-jest": "^28.6.0",
    "globals": "^15.15.0",
    "html-minifier": "^4.0.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli": "^0.41.0",
    "markdownlint-cli2": "^0.12.1",
    "postcss": "^8.4.39",
    "postcss-scss": "^4.0.9",
    "sass": "^1.77.6",
    "stylelint": "^16.6.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "tree-node-cli": "^1.6.0",
    "glob": "^10.4.2",
    "ignore": "^5.3.1"
  },
  "dependencies": {
    "@google/gemini-cli": "^0.4.0",
    "copy-paste": "^2.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-promise": "^7.2.1",
    "jsdom": "^24.1.0",
    "node-fetch": "^3.3.2",
    "terser": "^5.44.0"
  }
}
