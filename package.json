{
  "name": "joodug",
  "version": "1.0.6",
  "description": "A unified development and deployment workspace for Glitch projects.",
  "type": "module",
  "private": true,
  "scripts": {
    "deploy": "npm run sync && npm run lint:fix && npm run build:apps && npm run test",
    "//--- SETUP & SYNC ---": "",
    "setup": "npm install && npm run sync && npm run build:apps",
    "sync": "node build/scripts/sync.js --all",
    "sync:ignores": "node build/scripts/sync.js --ignores",
    "sync:mcp": "node build/scripts/sync.js --mcp",
    "sync:libs": "node build/scripts/sync.js --libs",
    "sync:hub": "node build/scripts/sync.js --hub",
    "//--- LINTING & TESTING ---": "",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html && npm run lint:md",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:css": "stylelint \"**/*.scss\" --config stylelint.config.cjs",
    "lint:css:fix": "stylelint \"**/*.scss\" --config stylelint.config.cjs --fix",
    "lint:html": "node -e \"require('glob').glob('apps/**/*.html', { ignore: ['build/output/**/*.html', '**/coverage/**/*'] }).then(files => require('child_process').execSync(`npx htmlhint ${files.join(' ')}`, { stdio: 'inherit' }))\"",
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.jsonc",
    "test": "jest",
    "//--- BUILDING ---": "",
    "build:apps": "npm run build:rpglitch && npm run build:imageglitch",
    "build:combine": "node build/scripts/build-combine.cjs",
    "build:hub": "node build/scripts/sync.js --hub",
    "build:imageglitch": "node build/scripts/build-app.js imageglitch",
    "build:rpglitch": "node build/scripts/build-app.js rpglitch",
    "//--- MCP SERVERS ---": "",
    "sync:mcp:claude": "node build/scripts/sync.js --mcp --claude",
    "mcp:sync-to-claude-code": "npm run sync:mcp:claude",
    "mcp:start-all": "echo 'MCP servers configured in mcp.master.json - start via Claude Code or IDE'",
    "test:env": "dotenv -- node -e \"console.log('SMITHERY_API_KEY:', process.env.SMITHERY_API_KEY ? 'Found' : 'Not found')\""
  },
  "keywords": [
    "ai",
    "agent",
    "monorepo"
  ],
  "author": "JooduG",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.56.1",
    "@smithery/cli": "^1.2.31",
    "@testing-library/jest-dom": "^6.9.1",
    "@waldzellai/clear-thought": "^0.0.4",
    "@waldzellai/metacognitive-monitoring": "^0.1.3",
    "@waldzellai/scientific-method": "^0.1.3",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.1.2",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^10.0.0",
    "esbuild": "^0.25.9",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.6.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-promise": "^7.2.1",
    "fake-indexeddb": "^6.2.4",
    "glob": "^10.4.5",
    "globals": "^15.15.0",
    "html-minifier": "^4.0.0",
    "htmlhint": "^1.1.4",
    "ignore": "^5.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint-cli": "^0.41.0",
    "markdownlint-cli2": "^0.12.1",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "rfdc": "^1.4.1",
    "sass": "^1.77.6",
    "stylelint": "^16.6.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "tree-node-cli": "^1.6.0"
  },
  "dependencies": {
    "@google/gemini-cli": "^0.4.0",
    "array-includes": "^3.1.9",
    "copy-paste": "^2.2.0",
    "dexie": "^4.2.1",
    "jsdom": "^24.1.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.56.1",
    "terser": "^5.44.0"
  }
}
