{
  "name": "rpglitch-perchance",
  "version": "1.0.0",
  "description": "RPGlitch - AI-powered storytelling platform for Perchance with comprehensive rules system for development",
  "main": "Perchance/build-perchance.js",
  "scripts": {
    "preflight": "npm run build && npm run lint && echo \"Preflight check complete (tests and typecheck not configured).\"",
    "build": "node Perchance/build-perchance.js",
    "build:watch": "nodemon --watch Perchance --ext html,js,css --exec 'node Perchance/build-perchance.js'",
    "lint": "eslint \"Perchance/**/*.js\" && stylelint \"**/*.{css,scss}\" && htmlhint \"Perchance/RPGlitch/RPGlitch.html\"",
    "validate": "node -e \"require('./Perchance/build-perchance.js').validateFiles()\"",
    "clean": "rm -rf Perchance/build/",
    "deploy": "npm run build && echo '✅ Build complete! Copy Perchance/build/RPGlitch-perchance.html to Perchance.'",
    "rules:update": "echo 'Use \"update memory bank\" to refresh memory bank files'"
  },
  "keywords": [
    "perchance",
    "rpglitch",
    "ai",
    "storytelling",
    "roleplay",
    "build-script"
  ],
  "author": "RPGlitch Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "htmlhint": "^1.6.3",
    "nodemon": "^3.0.0",
    "sass": "^1.77.4",
    "stylelint": "^16.21.1",
    "stylelint-config-standard": "^38.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/rpglitch-perchance.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/rpglitch-perchance/issues"
  },
  "homepage": "https://github.com/your-username/rpglitch-perchance#readme",
  "dependencies": {
    "@browsermcp/mcp": "^0.1.3",
    "@picocss/pico": "^2.1.1"
  }
}
