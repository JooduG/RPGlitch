{
  "name": "glitch-workspace",
  "version": "1.0.6",
  "description": "Unified workspace for Perchance.js apps, including RPGlitch and ImageGlitch.",
  "scripts": {
    "clean": "rm -rf build/output",
    "sync": "npm run sync:libs && npm run sync:configs && npm run sync:combine && npm run sync:hub",
    "sync:libs": "node build/scripts/sync-libs.js",
    "sync:configs": "node build/scripts/sync-configs.js",
    "sync:combine": "node build/scripts/sync-combine.js",
    "sync:hub": "node build/scripts/sync-hub.js",
    "build": "npm run clean && node build/scripts/build-rpglitch.js",
    "build:copy": "npm run clean && node build/scripts/build-and-copy.js",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.scss\"",
    "lint:html": "node build/scripts/background-htmlhint.js",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "test": "jest --json --outputFile=build/output/.jest-result.json || true",
    "deploy": "npm run sync && npm run test && npm run lint && npm run build",
    "deploy:ci": "CI=true npm run deploy"
  },
  "author": "JooduG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JooduG/default.git"
  },
  "bugs": {
    "url": "https://github.com/JooduG/default/issues"
  },
  "homepage": "https://github.com/JooduG/default#readme",
  "devDependencies": {
    "clipboardy": "4.0.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "eslint-plugin-promise": "6.2.0",
    "globals": "15.6.0",
    "htmlhint": "1.1.4",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "picomatch": "4.0.1",
    "prettier": "3.3.2",
    "sass": "1.77.6",
    "stylelint": "16.6.1",
    "stylelint-config-standard-scss": "13.1.0",
    "terser": "5.31.0",
    "tree-node-cli": "1.6.0"
  }
}
