{
  "compilerOptions": {
    "checkJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ]
  },
  "exclude": [
    "**/.git/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "*.bak",
    "*.css.map",
    "*.log",
    "*.tmp",
    ".env",
    ".env.*.local",
    ".env.local",
    ".gemini/",
    ".gitignore",
    ".mcp.json",
    ".npm",
    ".vscode/",
    "/.DS_Store",
    "/coverage",
    "/dist",
    "gha-creds-*.json",
    "libs/**",
    "llms.md",
    "mcp.json",
    "node_modules",
    "node_modules/",
    "nul",
    "scribbles.md",
    "scrubbles.md",
    "test-results/"
  ]
}
