{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@data/*": ["src/data/*"],
      "@state/*": ["src/state/*"],
      "@ui/*": ["src/ui/*"],
      "@atoms/*": ["src/ui/atoms/*"],
      "@utils/*": ["src/ui/utils/*"],
      "@theme/*": ["src/theme/*"],
      "@media/*": ["src/media/*"],
      "@devmode/*": ["src/ui/devmode/*"],
      "@drawer/*": ["src/ui/drawer/*"],
      "@profile/*": ["src/ui/profile/*"],
      "@storyboard/*": ["src/ui/storyboard/*"],
      "@storymode/*": ["src/ui/storymode/*"]
    },

    /* THE AI TYPE-SAFETY NET */
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "allowArbitraryExtensions": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/**/*",
    "types.d.ts",
    ".agents/skills/swarm/scripts/swarm-engine.js",
    ".agents/skills/data/scripts/knowledge.js"
  ],
  "exclude": [
    "**/.git/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "*.bak",
    "*.css.map",
    "*.log",
    "*.tmp",
    ".env",
    ".env.*.local",
    ".env.local",
    ".gemini/",
    ".gitignore",
    ".mcp.json",
    ".npm",
    ".vscode/",
    "**/.DS_Store",
    "**/coverage",
    "**/dist",
    "gha-creds-*.json",
    "libs/**",
    "llms.md",
    "mcp.json",
    "**/node_modules",
    "nul",
    "scribbles.md",
    "test-results/",
    ".jules/"
  ]
}
