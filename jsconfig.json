{
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["src/*"],
      "@actions": ["src/ui/actions/index.js"],
      "@actions/*": ["src/ui/actions/*"],
      "@motion": ["src/ui/motion/index.js"],
      "@motion/*": ["src/ui/motion/*"],
      "@atoms/*": ["src/ui/atoms/*"],
      "@components": ["src/ui/components/index.js"],
      "@components/*": ["src/ui/components/*"],
      "@data": ["src/data/index.js"],
      "@data/*": ["src/data/*"],
      "@devmode/*": ["src/ui/devmode/*"],
      "@drawer/*": ["src/ui/drawer/*"],
      "@engine": ["src/engine/index.js"],
      "@engine/*": ["src/engine/*"],
      "@intelligence": ["src/intelligence/index.js"],
      "@intelligence/*": ["src/intelligence/*"],
      "@media": ["src/media/index.js"],
      "@media/*": ["src/media/*"],
      "@platform": ["src/platform/index.js"],
      "@platform/*": ["src/platform/*"],
      "@profile/*": ["src/ui/profile/*"],
      "@state": ["src/state/index.js"],
      "@state/*": ["src/state/*"],
      "@storyboard/*": ["src/ui/storyboard/*"],
      "@storymode/*": ["src/ui/storymode/*"],
      "@ui/*": ["src/ui/*"]
    },
    "strict": true,
    "target": "esnext",
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "**/.git/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "*.bak",
    "*.css.map",
    "*.log",
    "*.tmp",
    ".env",
    ".env.*.local",
    ".env.local",
    ".gemini/",
    ".gitignore",
    ".mcp.json",
    ".npm",
    ".vscode/",
    "**/.DS_Store",
    "**/coverage",
    "**/dist",
    "gha-creds-*.json",
    "libs/**",
    "llms.md",
    "mcp.json",
    "**/node_modules",
    "nul",
    "scribbles.md",
    "test-results/",
    ".jules/"
  ],
  "include": [
    "src/**/*",
    "types.d.ts",
    ".agents/skills/swarm/scripts/swarm-engine.js",
    ".agents/skills/data/scripts/knowledge.js"
  ]
}
