{
  "launch": {
    "configurations": [],
    "compounds": []
  },
  "files.exclude": {
    ".geminiignore": true,
    ".gemini/[!s]*": true,
    ".gemini/s[!e]*": true,
    "GEMINI.md": true,
    ".playwright-auth/**": true,
    "**/.DS_Store": true,
    "**/.eslintcache": true,
    "**/.eslintignore": true,
    "**/.gitignore": true,
    "**/.htmlhintignore": true,
    "**/.markdownlintignore": true,
    "**/.prettierignore": true,
    "**/.stylelintignore": true,
    "**/jsconfig.json": true,
    "**/node_modules/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/Thumbs.db": true,
    "**/yarn.lock": true,
    "mcp.json": true,
    "test-results/**": true,
    "tests/**": true
  },
  "css.validate": true,
  "html.validate.styles": false,
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "markdown.validate.enabled": true,
  "markdown.validate.ignoredLinks": [
    "always_on | on_change | manual",
    "high | medium | low",
    "./.agent/project-management/**",
    "../project-management/**",
    "./tracks/**",
    "../tracks/**",
    "./design.md",
    "../design.md",
    "../../.github/workflows/ai-fleet-dispatch.yml"
  ],
  "markdown.validate.referenceLinks.severity": "ignore",
  "stylelint.validate": [
    "css",
    "scss",
    "svelte"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "markdown.validate.referenceLinks.enabled": false
}
