{
  "launch": {
    "configurations": [],
    "compounds": []
  },
  "files.associations": {
    "*.geminiignore": "ignore",
    "*.antigravityignore": "ignore"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.eslintcache": true,
    "**/.eslintignore": true,
    "**/.gemini/[!s]*": true,
    "**/.gemini/s[!e]*": true,
    "**/.geminiignore": true,
    "**/.gitignore": true,
    "**/.htmlhintignore": true,
    "**/.markdownlintignore": true,
    "**/.playwright-auth/**": true,
    "**/.prettierignore": true,
    "**/.stylelintignore": true,
    "**/.antigravityignore": true,
    "**/Thumbs.db": true,
    "**/jsconfig.json": true,
    "**/mcp.json": true,
    "/.env": false,
    "**/node_modules/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/test-results/**": true,
    "**/tests/**": true,
    "DESIGN.md": true,
    "**/yarn.lock": true,
    "**/bun.lockb": true
  },
  "css.validate": true,
  "html.validate.styles": false,
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "markdown.validate.enabled": true,
  "markdown.validate.ignoredLinks": [
    "always_on | on_change | manual",
    "high | medium | low",
    "./.agent/orchestration/**",
    "../orchestration/**",
    "./tracks/**",
    "../tracks/**",
    "./design.md",
    "../design.md",
    "../../.github/workflows/ai-fleet-dispatch.yml"
  ],
  "markdown.validate.referenceLinks.severity": "ignore",
  "stylelint.validate": [
    "css",
    "svelte"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "markdown.validate.referenceLinks.enabled": false
}
