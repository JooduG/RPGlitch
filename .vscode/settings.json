{
  "css.validate": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "html.validate.styles": false,
  "launch": {
    "compounds": [],
    "configurations": []
  },
  "markdown.validate.enabled": true,
  "markdown.validate.ignoredLinks": [
    "always_on | on_change | manual",
    "high | medium | low",
    "./tasks/PRESENT.md",
    "**/skills/**",
    "**/GEMINI.md",
    "**/GEMINI.md#*",
    "**/rules/**",
    "**/package.json",
    "**/tasks/**",
    "**/workflows/**"
  ],
  "markdown.validate.referenceLinks.enabled": "ignore",
  "stylelint.validate": [
    "css",
    "svelte"
  ],
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.playwright-auth/**": true,
    "**/bun.lockb": true,
    "**/node_modules/**": true,
    "**/pnpm-lock.yaml": true,
    "**/Thumbs.db": true,
    "**/yarn.lock": true,
    "/.env": false
  }
}
