{
    "launch": {
        "configurations": [],
        "compounds": []
    },
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.hg": true,
        "**/.svn": true,
        "**/CVS": true,
        "**/Thumbs.db": true,
        "libs/**": true,
        "**/node_modules/**": true,
        "mcp.json": true,
        ".mcp.json": true,
        "**/.gitignore": true,
        "**/.prettierignore": true,
        "**/package-lock.json": true,
        "**/pnpm-lock.yaml": true,
        "**/yarn.lock": true,
        "**/.htmlhintignore": true,
        "**/.stylelintignore": true,
        "**/jsconfig.json": true,
        "test-results/**": true,
        ".codex/knowledge/**": true,
        ".codex/rules/**": true,
        ".codex/skills/**": true,
        ".codex/tasks/**": true,
        ".codex/workflows/**": true
    },
    "css.validate": true,
    "html.validate.styles": false,
    "typescript.tsdk": "node_modules\\typescript\\lib",
    "markdown.validate.enabled": true,
    "markdown.validate.ignoredLinks": [
        "always_on | on_change | manual",
        "high | medium | low",
        "Rule Name",
        "Skill Name",
        "Role Name",
        "Core Function",
        "High Level Goal",
        "Process",
        "Process Name",
        "./scripts/tool_name.py",
        "./scripts/tool_name.js",
        "./scripts/tool.js"
    ]
}
