{
  "css.validate": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "files.associations": {
    "*.antigravityignore": "ignore",
    "*.geminiignore": "ignore",
    "*.htmlhintignore": "ignore",
    "*.markdownlintignore": "ignore",
    "*.prettierignore": "ignore",
    "*.stylelintignore": "ignore"
  },
  "html.validate.styles": false,
  "launch": {
    "compounds": [],
    "configurations": []
  },
  "markdown.validate.enabled": true,
  "markdown.validate.ignoredLinks": [
    "always_on | on_change | manual",
    "high | medium | low",
    "./tasks/PRESENT.md"
  ],
  "markdown.validate.referenceLinks.enabled": "ignore",
  "stylelint.validate": [
    "css",
    "svelte"
  ],
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.playwright-auth/**": true,
    "**/bun.lockb": true,
    "**/node_modules/**": true,
    "**/pnpm-lock.yaml": true,
    "**/Thumbs.db": true,
    "**/yarn.lock": true,
    "/.env": false
  },
  "github-actions.workflows.pinned.workflows": []
}
