{
  "root": true,
  "extends": "eslint:recommended",
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "image": "readonly",
    "ai": "readonly",
    "Dexie": "readonly",
    "DOMPurify": "readonly"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      { "args": "none", "ignoreRestSiblings": true, "caughtErrors": "none" }
    ],
    "no-undef": "error",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["**/tests/**/*.js", "**/*.test.js"],
      "env": {
        "jest": true
      }
    },
    {
      "files": ["build/scripts/**/*.js", "tools/**/*.js"],
      "env": {
        "node": true
      },
      "globals": {
        "image": "readonly",
        "Dexie": "readonly"
      }
    }
  ]
}
