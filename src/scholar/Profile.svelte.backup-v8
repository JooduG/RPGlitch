                        width: 6px;
                    }
                    &::-webkit-scrollbar-thumb {
                        background: rgba(255, 255, 255, 0.15);
                        border-radius: 3px;
                    }
                }

                .rhythm-grid {
                    display: flex;
                    flex-direction: column;
                    gap: 24px;
                    padding: 0 1rem;
                }

                .dossier-row {
                    display: grid;
                    grid-template-columns: 80px 1fr;
                    gap: 1rem;
                    align-items: center;

                    .row-label-col {
                        text-align: right;
                        display: flex;
                        flex-direction: column;
                        align-items: flex-end;
                        justify-content: center;
                        position: relative;
