                        }

                        &:hover .row-icon {
                            color: var(--hero-color);
                        }
                    }

                    .row-content-col {
                        flex: 1;
                        display: grid;
                        gap: 1rem;
                        &.split {
                            grid-template-columns: 1fr 1fr;
                        }
                        &.full {
                            grid-template-columns: 1fr;
                        }

                        .data-box {
                            background: rgba(0, 0, 0, 0.3);
                            border: 1px solid rgba(255, 255, 255, 0.08);
                            border-radius: 8px;
                            padding: 16px;
                            position: relative;
                            min-height: 100px;
                            box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.4);
                            box-sizing: border-box;

                            .box-header {
                                display: flex;
                                gap: 6px;
                                align-items: center;
                                font-size: 0.65rem;
                                font-weight: 700;
                                color: var(--hero-color);
                                opacity: 0.8;
                                text-transform: uppercase;
                                margin-bottom: 8px;
                                letter-spacing: 0.05em;

                                .header-icon {
                                    width: 12px;
                                    height: 12px;
                                    opacity: 0.6;
                                }
                            }

                            &.mental {
                                border-left: 3px solid rgba(147, 51, 234, 0.4);
                            }
                            &.physical {
                                border-left: 3px solid rgba(34, 197, 94, 0.4);
                            }
                        }
                    }
                }

                /* Global hover effects */
                &:has(.data-box.physical:hover) .data-box.physical {
                    background: linear-gradient(
                        90deg,
                        rgba(34, 197, 94, 0.05) 0%,
                        rgba(0, 0, 0, 0.3) 100%
                    ) !important;
                }
                &:has(.data-box.mental:hover) .data-box.mental {
                    background: linear-gradient(
                        90deg,
                        rgba(147, 51, 234, 0.05) 0%,
                        rgba(0, 0, 0, 0.3) 100%
                    ) !important;
                }

                .spark-container {
                    position: relative;
                    height: 100%;
                    display: flex;
                    flex-direction: column;

                    textarea {
                        width: 100%;
                        height: 100%;
                        background: transparent;
                        border: none;
