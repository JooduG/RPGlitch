{
  "default_project": "memory-bank",
  "projects": {
    "memory-bank": {
      "name": "Active Memory",
      "description": "Default project for centralized knowledge management",
      "path": "Active"
    },
    "system-architecture": {
      "name": "System Architecture",
      "description": "Strategic system knowledge and architecture decisions",
      "path": "projects/system-architecture"
    },
    "strategic": {
      "name": "Strategic",
      "description": "Strategic role knowledge and patterns",
      "path": "orchestration/strategic"
    },
    "tactical": {
      "name": "Tactical",
      "description": "Tactical planning and coordination knowledge",
      "path": "orchestration/tactical"
    },
    "operational": {
      "name": "Operational",
      "description": "Implementation and execution knowledge",
      "path": "orchestration/operational"
    },
    "rpglitch": {
      "name": "RPGlitch",
      "description": "RPGlitch-specific project knowledge",
      "path": "apps/rpglitch"
    },
    "imageglitch": {
      "name": "ImageGlitch",
      "description": "ImageGlitch-specific project knowledge",
      "path": "apps/imageglitch"
    },
    "rules": {
      "name": "Development Rules",
      "description": "Rules and development guidelines",
      "path": "../rules"
    }
  },
  "settings": {
    "auto_save": false,
    "backup_enabled": true,
    "sync_interval": 300,
    "indexing": {
      "include_patterns": [
        "**/*.md",
        "**/*.mdc",
        "**/*.mdx"
      ],
      "exclude_patterns": [
        "**/node_modules/**",
        "**/.git/**",
        "**/build/**",
        "**/dist/**"
      ],
      "watch_directories": [
        "projects",
        "../rules"
      ]
    }
  }
}