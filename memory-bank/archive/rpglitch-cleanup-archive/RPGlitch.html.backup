<!-- RPGlitch - Pico CSS Framework -->
<link rel="stylesheet" href="https://unpkg.com/@picocss/pico@2.1.1/css/pico.min.css">

<!-- Hidden H1 for accessibility/SEO -->
<h1 id="hidden-h1-element" class="hidden">RPGlitch</h1>

<!-- Skip Link for Accessibility -->
<a href="#main" class="visually-hidden">Skip to main content</a>

<!-- Loading Modal - Removed 'open' attribute to fix loading bug -->
<dialog id="initial-page-loading-modal" class="initial-loading-modal" no-header>
  <div>Loading...</div>
</dialog>
<!-- Emergency Export Modal -->
<dialog id="emergency-export-ctn" class="emergency-export-container" no-header>
  <div class="emergency-export-content">
    <div class="emergency-export-warning-text">Error during load?</div>
    <button id="emergency-export-button" onclick="App.exportAllData()" class="secondary tab-button">Save All Data &#128190;</button>
    <button id="emergency-delete-data-button" onclick="App.deleteAllData()" class="secondary tab-button">Delete All Data &#128680;</button>
  </div>
</dialog>

<div id="main-content-wrapper" class="container-fluid">
  <div class="container-fluid">
    <nav id="top-bar" class="container-fluid top-bar">
      <div id="top-bar-left" class="top-bar-left">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" data-tab="storyboard" role="tab" aria-selected="false" tabindex="0" _="on click call App.selectTopBarTab('storyboard') then call App.updateTopBarUI()">Storyboard</button></li>
          <li><button class="secondary tab-button" data-tab="characters" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('characters') then call App.updateTopBarUI()">Character Workshop</button></li>
          <li><button class="secondary tab-button" data-tab="worlds" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('worlds') then call App.updateTopBarUI()">World Creation</button></li>
          <li><button class="secondary tab-button" data-tab="options" role="tab" aria-selected="false" tabindex="-1" _="on click call App.toggleOptionsChin() then call App.updateTopBarUI()">Options</button></li>
        </ul>
      </div>
      <div id="top-bar-center" class="top-bar-spacer">
        <div id="top-bar-notification-area" class="top-bar-notification-area-style"></div>
      </div>
      <div id="top-bar-right" class="top-bar-right">
        <div id="top-bar-user-character-info">
          <div id="top-bar-user-character-pic" class="profile-picture"></div>
          <span id="top-bar-user-character-name-text"></span>
        </div>
        <div id="top-bar-ai-character-info">
          <div id="top-bar-ai-character-pic" class="profile-picture"></div>
          <span id="top-bar-ai-character-name-text"></span>
        </div>
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" id="shuffle-button" _="on click call App._shuffleStoryboard()">Shuffle</button></li>
          <li><button class="primary" id="begin-story-button" _="on click call App.beginStory()">Begin Story</button></li>
          <li><button class="secondary button-hidden" id="form-cancel-button">Cancel</button></li>
          <li><button class="primary button-hidden" id="form-save-button">Save</button></li>
        </ul>
      </div>
    </nav>

    <!-- Profile Top Bars: Only one visible at a time on profile screens -->
    <nav id="profile-top-bar" class="container-fluid hidden">
      <div id="profile-top-bar-left">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" data-tab="storyboard" role="tab" aria-selected="false" tabindex="0" _="on click call App.selectTopBarTab('storyboard') then call App.updateTopBarUI()">Storyboard</button></li>
          <li><button class="secondary tab-button" data-tab="characters" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('characters') then call App.updateTopBarUI()">Character Workshop</button></li>
          <li><button class="secondary tab-button" data-tab="worlds" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('worlds') then call App.updateTopBarUI()">World Creation</button></li>
          <li><button class="secondary tab-button" data-tab="options" role="tab" aria-selected="false" tabindex="-1" _="on click call App.toggleOptionsChin() then call App.updateTopBarUI()">Options</button></li>
        </ul>
      </div>
      <div id="profile-top-bar-center">
        <div id="profile-top-bar-notification-area" class="top-bar-notification-area-style"></div>
      </div>
      <div id="profile-top-bar-right">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" id="profile-edit-button">Edit</button></li>
          <li><button class="secondary danger button-hidden" id="profile-delete-button">Delete</button></li>
          <li><button class="primary" id="profile-back-button">Back</button></li>
        </ul>
      </div>
    </nav>
    <nav id="world-profile-top-bar" class="container-fluid hidden">
      <div id="world-profile-top-bar-left">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" data-tab="storyboard" role="tab" aria-selected="false" tabindex="0" _="on click call App.selectTopBarTab('storyboard') then call App.updateTopBarUI()">Storyboard</button></li>
          <li><button class="secondary tab-button" data-tab="characters" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('characters') then call App.updateTopBarUI()">Character Workshop</button></li>
          <li><button class="secondary tab-button" data-tab="worlds" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('worlds') then call App.updateTopBarUI()">World Creation</button></li>
          <li><button class="secondary tab-button" data-tab="options" role="tab" aria-selected="false" tabindex="-1" _="on click call App.toggleOptionsChin() then call App.updateTopBarUI()">Options</button></li>
        </ul>
      </div>
      <div id="world-profile-top-bar-center">
        <div id="world-profile-top-bar-notification-area" class="top-bar-notification-area-style"></div>
      </div>
      <div id="world-profile-top-bar-right">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" id="world-profile-edit-button">Edit</button></li>
          <li><button class="secondary danger button-hidden" id="world-profile-delete-button">Delete</button></li>
          <li><button class="primary" id="world-profile-back-button">Back</button></li>
        </ul>
      </div>
    </nav>
    <nav id="story-profile-top-bar" class="container-fluid hidden">
      <div id="story-profile-top-bar-left">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" data-tab="storyboard" role="tab" aria-selected="false" tabindex="0" _="on click call App.selectTopBarTab('storyboard') then call App.updateTopBarUI()">Storyboard</button></li>
          <li><button class="secondary tab-button" data-tab="characters" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('characters') then call App.updateTopBarUI()">Character Workshop</button></li>
          <li><button class="secondary tab-button" data-tab="worlds" role="tab" aria-selected="false" tabindex="-1" _="on click call App.selectTopBarTab('worlds') then call App.updateTopBarUI()">World Creation</button></li>
          <li><button class="secondary tab-button" data-tab="options" role="tab" aria-selected="false" tabindex="-1" _="on click call App.toggleOptionsChin() then call App.updateTopBarUI()">Options</button></li>
        </ul>
      </div>
      <div id="story-profile-top-bar-center">
        <div id="story-profile-top-bar-notification-area" class="top-bar-notification-area-style"></div>
      </div>
      <div id="story-profile-top-bar-right">
        <ul class="tab-group left-tabs">
          <li><button class="secondary tab-button" id="story-profile-edit-button">Edit</button></li>
          <li><button class="secondary danger button-hidden" id="story-profile-delete-button">Delete</button></li>
          <li><button class="primary" id="story-profile-back-button">Back</button></li>
        </ul>
      </div>
    </nav>

    <!-- Chins: Only one visible at a time -->
    <div id="storyboard-chin" class="container-fluid hidden" data-chin="storyboard">
      <div class="chin-actions">
        <form role="search">
          <fieldset role="group">
            <input type="search" id="search-stories-input" name="search" placeholder="Search Stories" aria-label="Search Stories">
            <button type="submit" class="secondary tab-button">Search</button>
          </fieldset>
        </form>
        <div class="chin-actions-right">
          <button type="button" class="secondary tab-button" onclick="document.getElementById('upload-story-input').click();">
            Upload Story
          </button>
          <input type="file" id="upload-story-input" aria-label="Upload Story" class="file-input-hidden">
          <button id="new-story-button" class="secondary tab-button">New Story</button>
        </div>
      </div>
      <div id="chin-story-list" class="chin-list-grid"></div>
      <!-- Storyboard Chin Content Placeholder -->
    </div>
    <div id="character-workshop-chin" class="container-fluid hidden" data-chin="characters">
      <div class="chin-actions">
        <form role="search">
          <fieldset role="group">
            <input type="search" id="search-characters-input" name="search" placeholder="Search Characters" aria-label="Search Characters">
            <button type="submit" class="secondary tab-button">Search</button>
          </fieldset>
        </form>
        <div class="chin-actions-right">
          <button type="button" class="secondary tab-button" onclick="document.getElementById('upload-character-input').click();">
            Upload Character
          </button>
          <input type="file" id="upload-character-input" aria-label="Upload Character" class="file-input-hidden">
          <button id="create-character-button" class="secondary tab-button">Create Character</button>
        </div>
      </div>
      <div id="chin-character-list" class="chin-list-grid">
        <article class="character-card-landscape">
          <div class="card-grid">
            <div class="card-info">
              <header>
                <h4 class="margin-0">Starship AI "ADA"</h4>
              </header>
                              <p class="font-size-95 margin-top-05 line-height-13">
                The ever-helpful AI of the starship "Odyssey," tasked with crew support and mission analysis.
              </p>
              <small>Premade</small>
              <footer class="card-footer">
                <button class="secondary tab-button">Copy & Customize</button>
                <button class="secondary tab-button">Edit</button>
              </footer>
            </div>
            <div class="card-picture">
              <div class="profile-picture profile-picture-default">
                SA
              </div>
            </div>
          </div>
        </article></div>
      </div>
      <!-- Character Workshop Chin Content Placeholder -->
    </div>
    <div id="world-builder-chin" class="container-fluid hidden" data-chin="worlds">
      <div class="chin-actions">
        <form role="search">
          <fieldset role="group">
            <input type="search" id="search-worlds-input" name="search" placeholder="Search Worlds" aria-label="Search Worlds">
            <button type="submit" class="secondary tab-button">Search</button>
          </fieldset>
        </form>
        <div class="chin-actions-right">
          <button type="button" class="secondary tab-button" onclick="document.getElementById('upload-world-input').click();">
            Upload World
          </button>
          <input type="file" id="upload-world-input" aria-label="Upload World" class="file-input-hidden">
          <button id="create-world-button" class="secondary tab-button">Create World</button>
        </div>
      </div>
      <div id="chin-world-list" class="chin-list-grid"></div>
      <!-- World Builder Chin Content Placeholder -->
    </div>
    <div id="options-chin" class="container-fluid hidden" data-chin="options">
      <!-- Options Chin Content -->
      <div class="chin-options-actions chin-actions-flex">
        <button id="download-backup-button" class="secondary tab-button">Download Backup</button>
                  <div class="chin-actions-right chin-actions-right-flex">
          <button type="button" class="secondary tab-button" onclick="document.getElementById('upload-backup-input').click();">
            Upload Backup
          </button>
          <input type="file" id="upload-backup-input" aria-label="Upload Backup" class="file-input-hidden">
          <button id="start-fresh-button" class="secondary danger">Start Fresh</button>
        </div>
      </div>
      <div class="chin-options-grid">
        <div>
          <textarea id="opening-prompt-textarea" placeholder="Opening Prompt"></textarea>
        </div>
        <div>
          <textarea id="custom-story-js-textarea" placeholder="Custom Story JS"></textarea>
        </div>
      </div>
    </div>
  </div>
  <!-- Top Bar End -->

  <div class="container-fluid">
    <div class="container-fluid">
      <!-- CHIN AREA: Selects and Cards, always aligned with top bar -->
      <div class="container-fluid hidden" id="storyboard-screen">
        <header id="storyboard-title-area">
          <h2 id="storyboard-title"></h2>
        </header>
        <div id="storyboard-content" class="container-fluid">
          <div id="storyboard-columns">
            <div class="storyboard-cards-grid">
              <div class="storyboard-column"><article id="storyboard-ai-character-card" class="storyboard-card">
                <div id="storyboard-ai-character-select" class="card-title-dropdown"></div>
              </article></div>
              <div class="storyboard-column"><article id="storyboard-user-character-card" class="storyboard-card">
                <div id="storyboard-user-character-select" class="card-title-dropdown"></div>
              </article></div>
              <div class="storyboard-column"><article id="storyboard-world-card" class="storyboard-card">
                <div id="storyboard-world-select" class="card-title-dropdown"></div>
              </article></div>
            </div>
          </div>
        </div>
      </div>
      <!-- Main Area -->
      <main id="main" role="main" tabindex="-1">
        <div id="columns-wrapper">
          <!-- Middle Column: Main Screens -->
          <div id="middle-column"> 
            <!-- Character/World Form Screens -->
            <div id="character-form-screen" class="hidden">
              <!-- Content rendered by App.renderFormScreen -->
            </div>
            <div id="world-form-screen" class="hidden">
              <!-- Content rendered by App.renderFormScreen -->
            </div>
            <!-- Profile Screens -->
            <div id="character-profile-screen" class="hidden">
              <div class="profile-details-content-wrapper">
                <div class="profile-section profile-hero-section">
                  <!-- Content rendered by App.renderProfileScreen -->
                </div>
              </div>
            </div>
            <div id="world-profile-screen" class="hidden">
              <div class="profile-details-content-wrapper">
                <div class="profile-section profile-hero-section">
                  <!-- Content rendered by App.renderProfileScreen -->
                </div>
              </div>
            </div>
            <div id="story-profile-screen" class="hidden">
              <div class="story-profile-layout-container">
                <div id="story-profile-ai-character-display-area" class="story-profile-side-panel">
                  <!-- AI Character's profile picture and name loaded here -->
                </div>
                <div id="story-profile-chat-wrapper" class="story-profile-central-content">
                  <div id="story-profile-message-feed" class="message-feed-profile flex-grow">
                    <!-- Chat log, conclusion, title, cards will be rendered here -->
                  </div>
                  <div id="story-profile-actions" class="story-profile-form-actions">
                    <!-- Action buttons like Delete, Back will be rendered here -->
                  </div>
                </div>
                <div id="story-profile-user-character-display-area" class="story-profile-side-panel">
                  <!-- User's Character large image will be loaded here by JS -->
                </div>
              </div>
              <div id="memory-application-screen" class="hidden">
                <!-- Content will be rendered by App._renderMemoryApplicationScreen -->
              </div>
            </div>
            <!-- Premade Bank Screens -->
            <div id="premade-character-bank" class="hidden">
              <h2 class="premade-screen-title">Premade Characters</h2>
              <p class="premade-screen-description">Select a premade character to use its details in the creation form.</p>
              <div id="premade-character-only-list" class="grid-bank-container"></div>
            </div>
            <div id="premade-world-bank" class="hidden">
              <h2 class="premade-screen-title">Premade Worlds</h2>
              <p class="premade-screen-description">Select a premade world to use its details in the creation form.</p>
              <div id="premade-world-only-list" class="grid-bank-container"></div>
            </div>
            <!-- Chat Interface Screen -->
            <div id="chat-interface-screen" class="hidden">
              <div id="chat-screen-layout-container">
                <div id="ai-character-display-area" class="chat-side-panel">
                  <!-- AI Character's large image will be loaded here by JS -->
                </div>
                <div id="built-in-chat-interface-wrapper"> 
                  <div id="chat-background-ctn" class="chat-background-overlay"></div>
                  <div id="story-concluded-notice" class="message systemMessage hidden"><div class="messageWrap"><div class="messageContentContainer"><div class="messageText">This story has concluded.</div></div></div></div>
                  <div id="chat-feed" class="flex-grow pt-2"></div>
                  <div id="no-messages-notice" class="hidden p-4 mt-4">Type your reply below to continue the story.</div>
                  <div id="status-notifier" class="hidden" data-original-display-value="flex">
                    <span id="typing-indicator-text">Bot is thinking</span>
                    <div id="input-wrapper" class="p-2">
                      <div class="chat-input-flex-container"> 
                        <textarea id="message-input" placeholder="Type your reply here..."></textarea>
                        <div class="chat-send-button-container"> 
                          <button id="send-button" class="primary" aria-label="Send message">
                            <span class="button-text">Send</span>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                  <button id="conclude-story-chat-button" class="secondary tab-button">Conclude Story</button>
                </div>
                <div id="user-character-display-area" class="chat-side-panel">
                  <!-- User's Character large image will be loaded here by JS -->
                </div>
              </div>
            </div>
            <!-- End Chat Interface Screen -->
          </div>
          <!-- End Middle Column -->
        </div>
      </main>
      <!-- End Main Area -->
    </div>
  </div>
</div>
