{
  "mcpServers": {
    "Linear": {
      "command": "npx -y mcp-remote https://mcp.linear.app/sse",
      "env": {}
    },
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "disabled": false,
      "autoApprove": []
    },
    "browser-tools": {
      "command": "npx @agentdeskai/browser-tools-mcp@1.2.0"
    },
    "time": {
      "command": "python",
      "args": ["-m", "mcp_server_time"]
    }
  }
}


