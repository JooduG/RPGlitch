#### **Caching Strategy**
```javascript
const cacheStrategy = {
  sharedRules: new Map(),
  modeSpecificRules: new Map(),
  contextRules: new Map(),
  
  get(key, category) {
    const cache = this[category + 'Rules'];
    return cache.get(key);
  },
  
  set(key, value, category) {
    const cache = this[category + 'Rules'];
    cache.set(key, {
      value: value,
      timestamp: Date.now(),
      ttl: this.getTTL(category)
    });
  }
};
```

