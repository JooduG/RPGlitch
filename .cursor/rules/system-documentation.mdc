## 🔍 **INTELLIGENT SOURCE SELECTION**

### **Query Analysis Algorithm**

```javascript
function analyzeQuery(query) {
  return {
    type: classifyQueryType(query),
    scope: determineScope(query),
    urgency: assessUrgency(query),
    specificity: assessSpecificity(query)
  };
}

function classifyQueryType(query) {
  if (query.includes('project') || query.includes('local')) return 'project-specific';
  if (query.includes('library') || query.includes('api')) return 'external-docs';
  if (query.includes('general') || query.includes('basic')) return 'general';
  return 'mixed';
}

function selectSources(queryAnalysis) {
  const sources = [];
  
  // Always include project memory for context
  sources.push('memory-bank');
  
  // Add external docs for library/API queries
  if (queryAnalysis.type === 'external-docs' || queryAnalysis.type === 'mixed') {
    sources.push('context7');
  }
  
  // Add general knowledge as fallback
  if (queryAnalysis.specificity === 'low') {
    sources.push('general');
  }
  
  return sources;
}
```

