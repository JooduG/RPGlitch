        "--profile",
        "${SMITHERY_PROFILE}"
      ],
      "autoStart": true,
      "description": "NPM package sentinel analysis via Smithery MCP (stdio)."
    },
    "HuggingFaceMCPServer": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
