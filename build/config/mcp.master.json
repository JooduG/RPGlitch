        "${SMITHERY_API_KEY}",
        "--profile",
        "${SMITHERY_PROFILE}"
      ],
      "autoStart": true,
      "description": "Multi-agent debate tools via Smithery MCP (stdio)."
    },
    "NPMSentinelMCP": {
