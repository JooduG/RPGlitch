{
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "http"
    },
    "markitdown": {
      "command": "uvx",
      "args": [
        "markitdown-mcp"
      ],
      "type": "stdio",
      "autoStart": true
    },
    "time": {
      "command": "python",
      "args": [
        "-m",
        "mcp_server_time"
      ],
      "env": {
        "TZ": "Europe/Stockholm"
      },
      "autoStart": true,
      "description": "Provides tools to get the current time and date. To start, run: python -m mcp_server_time"
    },
    "Context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "mcp-sequentialthinking-tools": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-sequentialthinking-tools"
      ],
      "type": "stdio",
      "pollingInterval": 30000,
      "startupTimeout": 30000,
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides advanced sequential thinking tools with persistent state. To start, run: npx -y mcp-sequentialthinking-tools"
    },
    "pollinations": {
      "command": "npx",
      "args": [
        "-y",
        "@pollinations/model-context-protocol"
      ],
      "type": "stdio",
      "pollingInterval": 30000,
      "startupTimeout": 30000,
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides AI image generation and creative tools through Pollinations services. To start, run: npx -y @pollinations/model-context-protocol"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${input}",
        "."
      ],
      "env": {},
      "autoApprove": [
        "read_file",
        "write_file",
        "list_dir"
      ],
      "autoStart": true,
      "description": "Portable filesystem server",
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "autoApprove": [
        "open_page",
        "screenshot"
      ],
      "autoStart": true
    },
    "Toolbox": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@smithery/toolbox",
        "--key",
        "${SMITHERY_API_KEY}",
        "--profile",
        "${SMITHERY_PROFILE}"
      ],
      "env": {},
      "autoStart": true
    },
    "basic-memory": {
      "type": "http",
      "url": "https://server.smithery.ai/@basicmachines-co/basic-memory/mcp?api_key=${SMITHERY_API_KEY}",
      "description": "Basic Memory MCP server via Smithery (API key via .env).",
      "env": {
        "BASIC_MEMORY_PROJECT_ROOT": "C:\\Users\\johng\\Documents\\GitHub\\default\\memory-bank"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "microsoft-docs": {
      "url": "https://learn.microsoft.com/api/mcp",
      "description": "Microsoft Docs MCP for documentation search and fetch."
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse",
      "description": "DeepWiki MCP over SSE for knowledge lookup."
    },
    "Multi-AgentDebate": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@albinjal/multi-agent-debate-mcp",
