        "-y",
        "@modelcontextprotocol/server-everything"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Convenience MCP exposing many demo tools in one server."
    },
    "SourcebotCodeSearchServer": {
      "type": "http",
      "url": "https://server.smithery.ai/@sourcebot-dev/sourcebot/mcp?api_key=${SOURCEBOT_API_KEY}&profile=${SOURCEBOT_PROFILE}",
