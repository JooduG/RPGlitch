{
  "$schema": "https://json.schemastore.org/prettierrc",
  "//": "This is the master file for all project ignore patterns.",

  "gitignore": {
    "patterns": [
      "/.DS_Store",
      "/.env.local",
      "/.env.*.local",
      "/node_modules",
      "/build/output",
      "/.npm",
      "/.vscode/*",
      "!/.vscode/settings.json",
      "!/.vscode/launch.json",
      "/.cursor/*",
      "!/.cursor/rules",
      "!/.cursor/mcp.json",
      "/.gemini/*",
      "!/.gemini/settings.json",
      "/.amazonq/*",
      "!/.amazonq/rules",
      "!/.amazonq/chat-preferences.json",
      "/.codacy-coverage",
      "/coverage",
      "/dist"
    ]
  },

  "ide": {
    "patterns": ["**/node_modules/**", "**/.git/**", "**/build/output/**"]
  },

  "memory": {
    "patterns": ["archive/", "past/", "diagnostics/"]
  },

  "linters": {
    "eslint": [
      "**/node_modules/**",
      "**/build/**",
      "**/dist/**",
      "**/*.min.js"
    ],
    "stylelint": ["**/node_modules/**", "**/build/**", "**/dist/**"],
    "htmlhint": ["**/node_modules/**", "**/build/**", "**/dist/**"],
    "markdownlint": ["**/node_modules/**", "**/CHANGELOG.md"]
  }
}
