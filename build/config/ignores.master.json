{
  "$schema": "https://json.schemastore.org/prettierrc",
  "gitignore": {
    "patterns": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "**/memory-bank/archive/**",
      "**/build/local_libs/**",
      "**/build/output/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.amazonq/rules/**",
      "/.basicmemoryignore",
      "/.cursor/mcp.json",
      "/.cursor/rules/**",
      "/.cursorignore",
      "/.env.*.local",
      "/.env.local",
      "/.gemini/settings.json",
      "/.geminiignore",
      "/.gitignore",
      "/.npm",
      "/.vscode/mcp.json",
      "/.vscode/settings.json",
      "/.windsurf/mcp.json",
      "/.windsurf/rules/**",
      "/coverage",
      "/dist",
      "/jsconfig.json",
      "/mcp.json",
      "/node_modules",
      ".htmlhintrc",
      ".markdownlint.json",
      "build/config/.htmlhintignore",
      "build/config/.markdownlintignore",
      "build/config/.stylelintignore",
      "build/config/ignore.eslint.json",
      "eslint.config.mjs",
      "jest.config.js",
      "memory-bank/scribbles.md",
      "stylelint.config.js"
    ]
  },
  "ide": {
    "patterns": [
      "**/build/local_libs/**",
      "**/node_modules/**",
      "**/archive/**",
      "**/memory-bank/archive/**",
      "**/build/local_libs/**",
      "**/build/output/**"
        ]
  },
  "memory": {
    "patterns": [
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules/**",
      "diagnostics/"
    ]
  },
  "linters": {
    "eslint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.amazonq/rules/",
      "/.basicmemoryignore",
      "/.cursor/rules/",
      "/.cursorignore",
      "/.geminiignore",
      "/.gitignore",
      "/.npm",
      "/.windsurf/rules/",
      "/coverage",
      "/dist",
      "/node_modules",
      "build/config/ignore.eslint.json",
      "eslint.config.mjs",
      "jest.config.js",
      "stylelint.config.js"
    ],
    "stylelint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.amazonq/rules/",
      "/.basicmemoryignore",
      "/.cursor/rules/",
      "/.cursorignore",
      "/.geminiignore",
      "/.gitignore",
      "/.npm",
      "/.windsurf/rules/",
      "/coverage",
      "/dist",
      "/node_modules",
      "build/config/.stylelintignore",
      "stylelint.config.js"
    ],
    "htmlhint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.amazonq/rules/",
      "/.basicmemoryignore",
      "/.cursor/rules/",
      "/.cursorignore",
      "/.geminiignore",
      "/.gitignore",
      "/.npm",
      "/.windsurf/rules/",
      "/coverage",
      "/dist",
      "/node_modules",
      ".htmlhintrc",
      "build/config/.htmlhintignore"
    ],
    "markdownlint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.amazonq/rules/",
      "/.basicmemoryignore",
      "/.cursor/rules/",
      "/.cursorignore",
      "/.geminiignore",
      "/.gitignore",
      "/.npm",
      "/.windsurf/rules/",
      "/coverage",
      "/dist",
      "/node_modules",
      ".markdownlint.json",
      "build/config/.markdownlintignore",
      "memory-bank/scribbles.md"
    ]
  },
  "vscode": {
    "filesExclude": {
      ".amazonq/rules/": true,
      ".basicmemoryignore": true,
      ".cursor/mcp.json": true,
      ".cursor/rules/": true,
      ".cursorignore": true,
      ".geminiignore": true,
      ".gitignore": true,
      ".htmlhintrc": true,
      ".markdownlint.json": true,
      ".vscode/mcp.json": true,
      ".vscode/rules/": true,
      ".windsurf/mcp.json": true,
      ".windsurf/rules/": true,
      "**/.DS_Store": true,
      "**/.git": true,
      "**/.hg": true,
      "**/.svn": true,
      "**/CVS": true,
      "**/Thumbs.db": true,
      "**/build/local_libs/**": true,
      "**/node_modules/**": true,
      "build/config/.htmlhintignore": true,
      "build/config/.markdownlintignore": true,
      "build/config/.stylelintignore": true,
      "build/config/ignore.eslint.json": true,
      "eslint.config.mjs": true,
      "jest.config.js": true,
      "jsconfig.json": true,
      "**/mcp.json": true,
      "stylelint.config.js": true,
      "test-basic-memory/": true
    }
  }
}