{
  "common": [
    "!.gemini/settings.json",
    "!dist/RPGlitch-left-panel.txt",
    "!src/RPGlitch-left-panel.txt",
    "*.bak",
    "*.log",
    "*.tmp",
    "**/.git/**",
    "**/*.scss.template",
    "**/*.template",
    "**/archive/**",
    "**/node_modules/**",
    "**/templates/**",
    "**/.gemini/**",
    ".geminiignore",
    ".gitignore",
    "/.DS_Store",
    "/.env",
    "dist/index.html",
    "mcp.json",
    "node_modules",
    "**/scribbles/**",
    "test-results/**",
    ".playwright-auth/**",
    "GEMINI.md"
  ],
  "geminiignore": [
    "!**/.env",
    "!**/.agent/**",
    "!**/.gemini/**",
    "!**/.geminiignore",
    "!**/.git/**",
    "!**/mcp.json",
    "!**/index/**",
    "!**/RPGlitch-left-panel.txt",
    "!**/templates/**",
    "!**/test-results/**",
    "!**/scribbles/**",
    "!**/.playwright-auth/**"
  ],
  "gitignore": ["!**/RPGlitch-left-panel.txt", "**/.eslintcache", "!GEMINI.md", "AGENTS.md"],
  "linters": {
    "eslint": [],
    "htmlhint": [],
    "markdownlint": [],
    "prettier": [],
    "stylelint": []
  },
  "vscode": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.fixAll.stylelint": "explicit"
    },
    "files.exclude": {
      ".geminiignore": true,
      ".gemini/[!s]*": true,
      ".gemini/s[!e]*": true,
      "GEMINI.md": true,
      ".playwright-auth/**": true,
      "**/.DS_Store": true,
      "**/.eslintcache": true,
      "**/.eslintignore": true,
      "**/.gitignore": true,
      "**/.htmlhintignore": true,
      "**/.markdownlintignore": true,
      "**/.prettierignore": true,
      "**/.stylelintignore": true,
      "**/jsconfig.json": true,
      "**/node_modules/**": true,
      "**/package-lock.json": true,
      "**/pnpm-lock.yaml": true,
      "**/Thumbs.db": true,
      "**/yarn.lock": true,
      "mcp.json": true,
      "test-results/**": true
    },
    "markdown.validate.referenceLinks.enabled": false,
    "stylelint.validate": ["css", "scss", "svelte"]
  }
}
