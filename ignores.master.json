{
  "gitignore": [
    "*.bak",
    "*.log",
    "*.tmp",
    "**/.git/**",
    "**/archive/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "libs/**",
    "apps/rpglitch/RPGlitch.html",
