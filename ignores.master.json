{
  "common": [
    "*.tmp",
    "*.template",
    "*.log",
    "*.bak",
    "**/yarn.lock",
    "**/test-results/**",
    "**/templates/**",
    "**/scribbles/**",
    "**/public/assets/**",
    "**/pnpm-lock.yaml",
    "**/package-lock.json",
    "**/out/**",
    "**/node_modules/**",
    "**/mcp.json",
    "**/dist/**",
    "**/coverage/**",
    "**/build/**",
    "**/archive/**",
    "**/__snapshots__/**",
    "**/Thumbs.db",
    "**/.turbo/**",
    "**/.stylelintignore",
    "**/.prettierignore",
    "**/.playwright-auth/**",
    "**/.next/**",
    "**/.markdownlintignore",
    "**/.htmlhintignore",
    "**/.gitignore",
    "**/.git/**",
    "**/.geminiignore",
    "**/.eslintcache",
    "**/.env.*",
    "**/.env",
    "**/.antigravityignore",
    "**/.DS_Store"
  ],
  "geminiignore": [
    "!**/test-results/**",
    "!**/templates/**",
    "!**/scribbles/**",
    "!**/rpglitch-left-panel.txt",
    "!**/mcp.json",
    "!**/index/**",
    "!**/.playwright-auth/**",
    "!**/.git/**",
    "!**/.geminiignore",
    "!**/.gemini/**",
    "!**/.env"
  ],
  "gitignore": ["**/.gemini/**", "!**/rpglitch-left-panel.txt", ".playwright-auth/**"],
  "antigravityignore": [],
  "linters": {
    "eslint": [],
    "htmlhint": [],
    "markdownlint": [],
    "prettier": [],
    "stylelint": []
  },
  "vscode": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.fixAll.stylelint": "explicit"
    },
    "files.exclude": {
      "**/.DS_Store": true,
      "**/.eslintcache": true,
      "**/.eslintignore": true,
      "**/.gemini/[!s]*": true,
      "**/.gemini/s[!e]*": true,
      "**/.geminiignore": true,
      "**/.gitignore": true,
      "**/.htmlhintignore": true,
      "**/.markdownlintignore": true,
      "**/.playwright-auth/**": true,
      "**/.prettierignore": true,
      "**/.stylelintignore": true,
      "**/.antigravityignore": true,
      "**/Thumbs.db": true,
      "**/jsconfig.json": true,
      "**/mcp.json": true,
      "**/node_modules/**": true,
      "**/package-lock.json": true,
      "**/pnpm-lock.yaml": true,
      "**/test-results/**": true,
      "**/tests/**": true,
      "DESIGN.md": true,
      "**/yarn.lock": true
    },
    "markdown.validate.referenceLinks.enabled": false,
    "stylelint.validate": ["svelte", "css"]
  }
}
