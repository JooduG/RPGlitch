{
  "gitignore": [
    "*.bak",
    "*.log",
    "*.tmp",
    "**/.git/**",
    "**/archive/**",
    "**/memory-bank/archive/**",
    "**/build/local_libs/**",
    "**/build/output/**",
    "/.DS_Store",
    ".env",
    ".env.*.local",
    ".env.local",
    ".gemini/",
    ".gitignore",
    ".npm",
    ".vscode/",
    "/coverage",
    "/dist",
    "**mcp.json",
    "node_modules/",
    "gha-creds-*.json"
  ],
  "memory": [
    "**/.git/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "**/build/output/**",
    "**/node_modules/**",
    "**/diagnostics/**"
  ],
  "linters": {
    "eslint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      "/node_modules"
    ],
    "stylelint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      "/node_modules"
    ],
    "htmlhint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      "/node_modules"
    ],
    "markdownlint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/",
      "**/build/local_libs/**",
      "**/node_modules**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      "/node_modules",
      ".markdownlint.json",
      "build/config/.markdownlintignore",
      "memory-bank/scribbles.md"
    ]
  },
  "vscode": {
    "filesExclude": {
      "**/.DS_Store": true,
      "**/.git": true,
      "**/.hg": true,
      "**/.svn": true,
      "**/CVS": true,
      "**/Thumbs.db": true,
      "**/build/local_libs/**": true,
      "**/node_modules/**": true
    }
  }
}
