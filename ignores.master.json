{
    "common": [
        "**/*.template",
        "**/templates/**",
        "**/*.scss.template",
        "*.bak",
        "*.log",
        "*.tmp",
        "**/.git/**",
        "**/node_modules/**",
        "/.DS_Store",
        "dist/index.html",
        "!dist/RPGlitch-left-panel.txt",
        "!src/RPGlitch-left-panel.txt",
        "test-results/**",
        ".gitignore",
        "mcp.json",
        "**/archive/**",
        "/.env",
        "node_modules",
        ".gemini"
    ],
    "gitignore": [".env"],
    "linters": {
        "eslint": [],
        "stylelint": [],
        "htmlhint": [],
        "markdownlint": [],
        "prettier": ["package-lock.json", "pnpm-lock.yaml", "yarn.lock"]
    },
    "vscode": {
        "files.exclude": {
            "**/.DS_Store": true,
            "**/Thumbs.db": true,
            "**/node_modules/**": true,
            "mcp.json": true,
            "**/.gitignore": true,
            "**/.prettierignore": true,
            "**/package-lock.json": true,
            "**/pnpm-lock.yaml": true,
            "**/yarn.lock": true,
            "**/.htmlhintignore": true,
            "**/.stylelintignore": true,
            "**/.eslintignore": true,
            "**/.markdownlintignore": true,
            "**/jsconfig.json": true,
            "test-results/**": true
        },
        "markdown.validate.referenceLinks.enabled": false
    }
}
