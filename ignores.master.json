{
  "antigravityignore": [],
  "common": [
    "!**/.env.example",
    "*.bak",
    "*.log",
    "*.template",
    "*.tmp",
    ".secrets",
    "**/.DS_Store",
    "**/.antigravityignore",
    "**/.env*",
    "**/.eslintcache",
    "**/.geminiignore",
    "**/.git/**",
    "**/.gitignore",
    "**/.htmlhintignore",
    "**/cache/**",
    "**/.markdownlintignore",
    "**/.next/**",
    "**/.playwright-auth/**",
    "**/.prettierignore",
    "**/.stylelintignore",
    "**/.turbo/**",
    "**/Thumbs.db",
    "**/__snapshots__/**",
    "**/archive/**",
    "**/build/**",
    "**/bun.lockb",
    "**/coverage/**",
    "**/dist/**",
    "**/mcp.json",
    "**/node_modules/**",
    "**/out/**",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/public/assets/**",
    "**/scribbles/**",
    "**/templates/**",
    "**/test-results/**",
    "**/yarn.lock",
    "**/tmp/**",
    "**/svelte-devtools/**"
  ],
  "geminiignore": [
    "!**/.env",
    "!**/.git/**",
    "!**/index/**",
    "!**/mcp.json",
    "!**/rpglitch-left-panel.txt",
    "!**/scribbles/**",
    "!**/templates/**",
    "!**/test-results/**",
    "!**/tmp/**"
  ],
  "gitignore": [
    "!**/rpglitch-left-panel.txt",
    "!**/templates/**",
    ".secrets",
    "**/.jules/**",
    "act_output.log",
    "gha-creds-*.json"
  ],
  "linters": {
    "eslint": [],
    "htmlhint": ["**/*.svelte"],
    "markdownlint": [],
    "prettier": [],
    "stylelint": []
  },
  "vscode": {
    "files.exclude": {
      "**/.DS_Store": true,
      "**/.playwright-auth/**": true,
      "**/bun.lockb": true,
      "**/node_modules/**": true,
      "**/pnpm-lock.yaml": true,
      "**/Thumbs.db": true,
      "**/yarn.lock": true,
      "/.env": false
    }
  }
}
