    "stylelint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "apps/rpglitch/RPGlitch.html",
      "apps/imageglitch/imageglitch.html",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist"
    ],
    "htmlhint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "apps/rpglitch/RPGlitch.html",
      "apps/imageglitch/imageglitch.html",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist"
    ],
    "markdownlint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "apps/rpglitch/RPGlitch.html",
      "apps/imageglitch/imageglitch.html",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      ".markdownlint.json",
      ".markdownlint.json"
    ]
  },
  "vscode": {
    "filesExclude": {
      "**/.DS_Store": true,
      "**/.hg": true,
      "**/.svn": true,
      "**/CVS": true,
      "**/Thumbs.db": true,
      "**/build/local_libs/**": false,
      "libs/**": true,
      "**/node_modules/**": true
