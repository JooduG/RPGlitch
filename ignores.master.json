{
  "common": [
    "!**/.gemini/settings.json",
    "!**/rpglitch-left-panel.txt",
    "!**/src/rpglitch-left-panel.txt",
    "*.bak",
    "*.log",
    "*.tmp",
    "**/.git/**",
    "**/*.template**",
    "**/archive/**",
    "**/node_modules/**",
    "**/templates/**",
    "**/GEMINI.md",
    "**/.gemini/**",
    "**/.geminiignore",
    "**/.gitignore",
    "**/.DS_Store",
    "**/.env",
    "**/dist/index.html",
    "**/mcp.json",
    "**/scribbles/**",
    "**/test-results/**",
    "**/.playwright-auth/**",
    "**/skills/**/assets/**",
    "**/skills/**/references/**"
  ],
  "geminiignore": [
    "!**/.env",
    "**/.agent/**",
    "**/AGENTS.md",
    "!**/.gemini/**",
    "!**/GEMINI.md",
    "!**/.geminiignore",
    "!**/.git/**",
    "!**/mcp.json",
    "!**/index/**",
    "!**/rpglitch-left-panel.txt",
    "!**/templates/**",
    "!**/test-results/**",
    "!**/scribbles/**",
    "!**/.playwright-auth/**",
    "!**/skills/**/assets/**",
    "!**/skills/**/references/**"
  ],
  "gitignore": [
    "!**/rpglitch-left-panel.txt",
    "**/.eslintcache",
    "!**/GEMINI.md",
    "**/.playwright-auth/**",
    "!**/skills/**/assets/**",
    "!**/skills/**/references/**",
    "!**/.gemini/settings.json"
  ],
  "linters": {
    "eslint": [],
    "htmlhint": [],
    "markdownlint": [],
    "prettier": [],
    "stylelint": []
  },
  "vscode": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.fixAll.stylelint": "explicit"
    },
    "files.exclude": {
      "**/.geminiignore": true,
      "**/.gemini/[!s]*": true,
      "**/.gemini/s[!e]*": true,
      "**/GEMINI.md": true,
      "**/.agent/settings.json": true,
      "**/.playwright-auth/**": true,
      "**/.DS_Store": true,
      "**/.eslintcache": true,
      "**/.eslintignore": true,
      "**/.gitignore": true,
      "**/.htmlhintignore": true,
      "**/.markdownlintignore": true,
      "**/.prettierignore": true,
      "**/.stylelintignore": true,
      "**/jsconfig.json": true,
      "**/node_modules/**": true,
      "**/package-lock.json": true,
      "**/pnpm-lock.yaml": true,
      "**/Thumbs.db": true,
      "**/yarn.lock": true,
      "**/mcp.json": true,
      "**/test-results/**": true,
      "**/tests/**": true
    },
    "markdown.validate.referenceLinks.enabled": false,
    "stylelint.validate": ["css", "svelte"]
  }
}
