{
  "gitignore": [
    "*.bak",
    "*.log",
    "*.tmp",
    "**/.git/**",
    "**/archive/**",
    "**/build/local_libs/**",
    "libs/**",
    "/.DS_Store",
    ".env",
    ".env.*.local",
    ".env.local",
    ".gemini/",
    ".gitignore",
    ".npm",
    ".vscode/",
    "/coverage",
    "/dist",
    "mcp.json",
    ".mcp.json",
    "node_modules/",
    "gha-creds-*.json",
    "nul",
    "*.css.map",
    "test-results/",
    "scribbles.md"
  ],
  "linters": {
    "eslint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist"
    ],
    "stylelint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist"
    ],
    "htmlhint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist"
    ],
    "markdownlint": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      ".markdownlint.json",
      "*.resolved",
      "scribbles.md"
    ],
    "prettier": [
      "*.bak",
      "*.log",
      "*.tmp",
      "**/.git/**",
      "**/archive/**",
      "libs/**",
      "**/node_modules/**",
      "/.DS_Store",
      "/.npm",
      "/coverage",
      "/dist",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock"
    ]
  },
  "vscode": {
    "filesExclude": {
      "**/.DS_Store": true,
      "**/.hg": true,
      "**/.svn": true,
      "**/CVS": true,
      "**/Thumbs.db": true,
      "libs/**": true,
      "**/node_modules/**": true,
      "mcp.json": true,
      ".mcp.json": true,
      "**/.gitignore": true,
      "**/.prettierignore": true,
      "**/package-lock.json": true,
      "**/pnpm-lock.yaml": true,
      "**/yarn.lock": true,
      "**/.htmlhintignore": true,
      "**/.stylelintignore": true,
      "**/jsconfig.json": true,
      "test-results/**": true
    }
  }
}
