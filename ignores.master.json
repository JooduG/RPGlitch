{
  "antigravityignore": [],
  "common": [
    "*.bak",
    "*.log",
    "*.template",
    "*.tmp",
    "**/*.lock",
    ".secrets",
    "**/.DS_Store",
    "**/.env*",
    "**/.eslintcache",
    "**/.git/**",
    "**/cache/**",
    "**/.next/**",
    "**/.playwright-auth/**",
    "**/*ignore",
    "**/.turbo/**",
    "**/Thumbs.db",
    "**/__snapshots__/**",
    "**/archive/**",
    "**/build/**",
    "**/bun.lockb",
    "**/coverage/**",
    "**/dist/**",
    "**/mcp.json",
    "**/node_modules/**",
    "**/out/**",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/public/assets/**",
    "**/*scribbles**",
    "**/templates/**",
    "**/test-results/**",
    "**/yarn.lock",
    "**/tmp/**",
    "tmp/**/*",
    "**/view-transitions-svelte.md",
    "**/.understand-anything/**"
  ],
  "geminiignore": [
    "!**/*.env",
    "!**/*.git/**",
    "!**/*index**",
    "!**/*mcp.json",
    "!**/*rpglitch-left-panel.txt",
    "!**/*scribbles**",
    "!**/templates/**",
    "!**/test-results/**",
    "!**/tmp/**",
    "!tmp/**/*"
  ],
  "gitignore": ["!**/*rpglitch-left-panel.txt", "!**/templates/**", ".secrets", "**/.jules/**", "act_output.log", "gha-creds-*.json", "**/*ignore"],
  "linters": {
    "eslint": [],
    "htmlhint": ["**/*.svelte"],
    "markdownlint": ["**/modern-web-guidance/guides/**", "view-transitions-svelte.md"],
    "prettier": [],
    "stylelint": []
  },
  "vscode": {
    "files.exclude": {
      "**/.DS_Store": true,
      "**/.playwright-auth/**": true,
      "**/bun.lockb": true,
      "**/node_modules/**": true,
      "**/pnpm-lock.yaml": true,
      "**/Thumbs.db": true,
      "**/yarn.lock": true,
      "**/.env": false,
      "**/src/**/index.js": true
    }
  }
}
