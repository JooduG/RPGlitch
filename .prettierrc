{
  "plugins": ["prettier-plugin-svelte"],
  "pluginSearchDirs": ["."],
  "overrides": [
    {
      "files": "*.svelte",
      "options": {
        "parser": "svelte"
      }
    },
    {
      "files": "*.json",
      "options": {
        "parser": "json",
        "tabWidth": 4
      }
    }
  ],
  "trailingComma": "es5",
  "tabWidth": 4,
  "semi": false,
  "singleQuote": false
}
