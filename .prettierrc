{
    "plugins": ["prettier-plugin-svelte"],
    "printWidth": 300,
    "pluginSearchDirs": ["."],
    "overrides": [
        {
            "files": "*.svelte",
            "options": {
                "parser": "svelte"
            }
        },
        {
            "files": "*.json",
            "options": {
                "parser": "json",
                "tabWidth": 4
            }
        },
        {
            "files": "*.jsonc",
            "options": {
                "parser": "json",
                "trailingComma": "none"
            }
        }
    ],
    "trailingComma": "es5",
    "tabWidth": 4,
    "semi": false,
    "singleQuote": false
}
