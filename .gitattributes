# Enforce LF line endings for all text files (prevents CRLF drift on Windows)
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.webm binary
*.wav binary
