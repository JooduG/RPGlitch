{
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false
  },
  "globs": [
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "design-system.md",
    "PERCHANCE.md",
    "perchance-development-guide.md",
    "plan.md",
    "apps/**/*.md",
    "docs/**/*.md",
    "tests/**/*.md"
  ],
  "ignores": [
    "**/.git/**",
    "**/archive/**",
    "**/node_modules/**",
    "*.bak",
    "*.log",
    "*.tmp",
    ".markdownlint.json",
    "/.DS_Store",
    "/.npm",
    "/coverage",
    "/dist",
    "apps/imageglitch/imageglitch.html",
    "apps/rpglitch/RPGlitch.html",
    "libs/**"
  ]
}
