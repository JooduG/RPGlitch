{
  "config": {
    "extends": ".markdownlint.json"
  },
  "ignores": [
    "**/.git/**",
    "**/archive/**",
    "**/node_modules/**",
    "*.bak",
    "*.log",
    "*.resolved",
    "*.tmp",
    ".markdownlint.json",
    "/.DS_Store",
    "/.npm",
    "/coverage",
    "/dist",
    "libs/**",
    "llms.md"
  ]
}
