{
  "theme": "Atom One",
  "selectedAuthType": "oauth-personal",
  "mcpServers": {
    "time": {
      "command": "python",
      "args": [
        "-m",
        "mcp_server_time"
      ],
      "env": {
        "TZ": "Europe/Stockholm"
      },
      "autoStart": true,
      "description": "Provides tools to get the current time and date."
    },
    "everything": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Official MCP demo server with many useful basic tools."
    },
    "pollinations": {
      "command": "npx",
      "args": [
        "-y",
        "@pollinations/model-context-protocol"
      ],
      "type": "stdio",
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides AI image generation through Pollinations services. 🎨"
    },
    "mcp-sequentialthinking-tools": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-sequentialthinking-tools"
      ],
      "type": "stdio",
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides advanced sequential thinking tools with persistent state."
    },
    "basic-memory-stdio": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "basic-memory",
        "mcp"
      ],
      "autoStart": true,
      "description": "Basic Memory MCP server via direct command."
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse",
      "description": "DeepWiki MCP over SSE for knowledge lookup."
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
        "Accept": "application/json, text/event-stream"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "autoApprove": [
        "open_page",
        "screenshot"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Lets the AI control a web browser for scraping and automation. 🌐"
    }
  }
}
