{
    "ui": {
        "accessibility": {
            "screenReader": false
        },
        "showMemoryUsage": false,
        "theme": "Atom One"
    },
    "context": {
        "loadMemoryFromIncludeDirectories": true,
        "fileFiltering": {
            "respectGitIgnore": false
        }
    },
    "security": {
        "folderTrust": {
            "featureEnabled": true,
            "enabled": true
        },
        "auth": {
            "selectedType": "gemini-api-key"
        }
    },
    "ide": {
        "hasSeenNudge": true,
        "enabled": true
    },
    "mcpServers": {
        "time": {
            "command": "python",
            "args": ["-m", "mcp_server_time"],
            "env": {
                "TZ": "Europe/Stockholm"
            },
            "description": "Provides tools to get the current time and date."
        },
        "toolbox": {
            "command": "cmd",
            "args": [
                "/c",
                "npx",
                "-y",
                "@smithery/cli@latest",
                "run",
                "@smithery/toolbox",
                "--key",
                "280e2eb3-2ed8-480d-a979-da7492da8ec1",
                "--profile",
                "voluntary-hornet-y52X3F"
            ]
        },
        "pollinations": {
            "command": "npx",
            "args": ["-y", "@pollinations/model-context-protocol"],
            "type": "stdio",
            "description": "Provides AI image generation through Pollinations services. 🎨"
        },
        "mcp-sequentialthinking-tools": {
            "command": "npx",
            "args": ["-y", "mcp-sequentialthinking-tools"],
            "type": "stdio",
            "description": "Provides advanced sequential thinking tools with persistent state."
        },
        "waldzell-clear-thought": {
            "command": "npx",
            "args": ["-y", "@waldzellai/clear-thought"],
            "type": "stdio",
            "description": "Provides sequential thinking tools from Waldzell."
        },
        "waldzell-stochastic-thinking": {
            "command": "npx",
            "args": ["-y", "@waldzellai/stochasticthinking"],
            "type": "stdio",
            "description": "Provides stochastic thinking utilities."
        },
        "deepwiki": {
            "url": "https://mcp.deepwiki.com/sse",
            "description": "DeepWiki MCP over SSE for knowledge lookup."
        },
        "playwright": {
            "command": "npx",
            "args": ["-y", "@playwright/mcp"],
            "type": "stdio",
            "description": "Lets the AI control a web browser for scraping and automation. 🌐"
        },
        "npm-sentinel": {
            "command": "npx",
            "args": ["-y", "@nekzus/mcp-server@latest"],
            "type": "stdio",
            "description": "An MCP server for analyzing NPM packages."
        },
        "chrome-devtools": {
            "command": "npx",
            "args": ["chrome-devtools-mcp@latest"]
        }
    },
    "general": {
        "enablePromptCompletion": true,
        "preferredEditor": "vscode"
    },
    "agentProtocolFile": "../GEMINI.md",
    "tools": {
        "useRipgrep": true
    }
}
