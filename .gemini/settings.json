{
  "agentProtocolFile": "../AGENTS.md",
  "ideMode": true,
  "mcpServers": {
    "time": {
      "command": "python",
      "args": [
        "-m",
        "mcp_server_time"
      ],
      "env": {
        "TZ": "Europe/Stockholm"
      },
      "autoStart": true,
      "description": "Provides tools to get the current time and date."
    },
    "toolbox": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@smithery/cli@latest",
        "run",
        "@smithery/toolbox",
        "--key",
        "280e2eb3-2ed8-480d-a979-da7492da8ec1",
        "--profile",
        "voluntary-hornet-y52X3F"
      ]
    },
    "pollinations": {
      "command": "npx",
      "args": [
        "-y",
        "@pollinations/model-context-protocol"
      ],
      "type": "stdio",
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides AI image generation through Pollinations services. 🎨"
    },
    "mcp-sequentialthinking-tools": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-sequentialthinking-tools"
      ],
      "type": "stdio",
      "restartOnFailure": true,
      "autoStart": true,
      "description": "Provides advanced sequential thinking tools with persistent state."
    },
    "waldzell-metagames": {
      "command": "npx",
      "args": [
        "-y",
        "waldzell-metagames-server"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Provides game-theoretic workflows for development."
    },
    "waldzell-clear-thought": {
      "command": "npx",
      "args": [
        "-y",
        "@waldzellai/clear-thought"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Provides sequential thinking tools from Waldzell."
    },
    "waldzell-stochastic-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@waldzellai/stochasticthinking"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Provides stochastic thinking utilities."
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/sse",
      "description": "DeepWiki MCP over SSE for knowledge lookup."
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-47294459-6c98-4af4-8546-a3616fe3d7d9",
        "Accept": "application/json, text/event-stream"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "autoApprove": [
        "open_page",
        "screenshot"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "Lets the AI control a web browser for scraping and automation. 🌐"
    },
    "npm-sentinel": {
      "command": "npx",
      "args": [
        "-y",
        "@nekzus/mcp-server@latest"
      ],
      "type": "stdio",
      "autoStart": true,
      "description": "An MCP server for analyzing NPM packages."
    }
  },
  "folderTrust": true,
  "theme": "Atom One",
  "showMemoryUsage": false,
  "accessibility": {
    "screenReader": true
  },
  "hasSeenIdeIntegrationNudge": true,
  "fileFiltering": {
    "respectGitIgnore": false
  },
  "folderTrustFeature": true,
  "selectedAuthType": "gemini-api-key",
  "tools": {
    "useRipgrep": true
  },
  "general": {
    "enablePromptCompletion": true
  },
  "preferredEditor": "vscode",
  "context": {
    "loadMemoryFromIncludeDirectories": true
  }
}
