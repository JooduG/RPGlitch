{
    "version": "1.0.0",
    "description": "Perchance Development Subagent Configuration",
    "subagent_routing": {
      "architecture": {
        "keywords": ["architecture", "design", "pattern", "scalability", "Two-Panel", "long-term"],
        "subagent": "perchance-architect",
        "priority": "high"
      },
      "planning": {
        "keywords": ["plan", "blueprint", "implement", "build", "feature", "task"],
        "subagent": "perchance-planner",
        "priority": "critical"
      },
      "coding": {
        "keywords": ["code", "write", "implement", "function", "module", "refactor"],
        "subagent": "perchance-coder",
        "priority": "high"
      },
      "ui": {
        "keywords": ["UI", "interface", "design", "button", "form", "layout", "accessibility", "label"],
        "subagent": "perchance-ui-ux",
        "priority": "high"
      },
      "security": {
        "keywords": ["test", "security", "XSS", "review", "lint", "verify"],
        "subagent": "perchance-security-qa",
        "priority": "high"
      },
      "debugging": {
        "keywords": ["error", "bug", "fail", "debug", "crash", "fix"],
        "subagent": "perchance-debugger",
        "priority": "high"
      },
      "testing": {
        "keywords": ["test", "jest", "coverage", "failing"],
        "subagent": "perchance-test-runner",
        "priority": "medium"
      },
      "memory": {
        "keywords": ["archive", "document", "handoff", "save", "preserve"],
        "subagent": "perchance-memory-keeper",
        "priority": "low"
      }
    },
    "model_selection": {
      "architect": "opus",
      "planner": "opus",
      "coder": "sonnet",
      "ui": "sonnet",
      "security": "haiku",
      "debugger": "sonnet",
      "test-runner": "haiku",
      "memory": "haiku"
    },
    "notes": "Model selection balances cost vs. capability. Opus for heavy thinking, Sonnet for general work, Haiku for pattern matching."
  }